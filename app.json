{
  "expo": {
    "name": "Voicemark",
    "slug": "voicemark",
    "scheme": "voicemark",
    "version": "0.3.0",
    "orientation": "portrait",
    "primaryColor": "#6B5B95",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.aqeelahmad.voicemark",
      "versionCode": 3,
      "permissions": ["RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#6B5B95"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAFAF7",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Voicemark needs the microphone to record your voice notes. Audio is processed on-device and never uploaded.",
          "speechRecognitionPermission": "Voicemark transcribes your voice notes on-device using speech recognition."
        }
      ],
      "expo-sqlite",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
